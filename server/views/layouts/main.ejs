<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">

  <!-- Primary Meta Tags -->
  <title>
    <%= meta.title %>
  </title>
  <meta name="description" content="<%= meta.description %>">
  <meta name="robots" content="<%= meta.robots %>">
  <link rel="canonical" href="<%= meta.canonical %>">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= meta.ogType || 'website' %>">
  <meta property="og:title" content="<%= meta.ogTitle %>">
  <meta property="og:description" content="<%= meta.ogDescription %>">
  <meta property="og:url" content="<%= meta.canonical %>">
  <% if (meta.ogImage) { %>
    <meta property="og:image" content="<%= meta.ogImage %>">
    <% } %>
      <meta property="og:locale" content="ar_SA">

      <!-- Twitter -->
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:title" content="<%= meta.ogTitle %>">
      <meta name="twitter:description" content="<%= meta.ogDescription %>">

      <!-- fonts -->
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">

      <script src="https://cdn.tailwindcss.com"></script>
      <link rel="stylesheet" href="/css/main.css">
      <%- typeof style !=='undefined' ? style : '' %>
</head>

<body class="bg-gray-50 text-gray-800">

  <%- include('../partials/header') %>

    <%- body %>

      <%- include('../partials/footer') %>

        <!-- Improved Coupon Modal -->
        <div id="coupon-modal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4 animate-fade-in">
          <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeModal()"></div>
          <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 text-center animate-modal-in"
            onclick="event.stopPropagation()">
            <!-- Close Button -->
            <button onclick="closeModal()"
              class="absolute top-4 left-4 text-gray-400 hover:text-gray-800 transition-colors z-20">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>

            <!-- Top Badges -->
            <div class="absolute top-4 right-4 flex items-center gap-2 text-[10px] font-bold">
              <span class="bg-red-100 text-red-600 px-2.5 py-1 rounded-full flex items-center gap-1">🔥 لا تفوت</span>
              <span class="bg-green-100 text-green-700 px-2.5 py-1 rounded-full flex items-center gap-1">✨ جديد</span>
            </div>

            <!-- Store Logo -->
            <div id="modal-logo" class="h-16 w-auto max-w-[150px] mx-auto mb-4 flex items-center justify-center">
              <img id="modal-logo-img" src="" alt="" class="h-full w-auto object-contain">
            </div>

            <h3 id="modal-store-name" class="hidden"></h3>
            <h2 id="modal-title" class="text-2xl font-bold text-gray-800 mb-6 leading-relaxed"></h2>

            <!-- Coupon Code Display -->
            <div id="modal-code-section" class="hidden mb-6">
              <div
                class="relative w-full bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl p-5 flex items-center justify-between group">
                <span id="modal-code"
                  class="font-mono text-2xl font-black text-blue-600 tracking-widest dir-ltr"></span>
                <button onclick="copyCodeOnly()" id="modal-copy-icon-btn"
                  class="p-2 hover:bg-gray-200 rounded-lg transition-colors">
                  <svg id="copy-icon" class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                    </path>
                  </svg>
                  <svg id="check-icon" class="w-6 h-6 text-green-600 hidden" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Deal Display -->
            <div id="modal-deal-section" class="hidden mb-6">
              <div class="bg-orange-50 border border-orange-100 rounded-xl p-4 text-orange-800 font-bold text-sm">
                لا تحتاج إلى كود! سيتم تطبيق الخصم تلقائياً عند الانتقال للمتجر.
              </div>
            </div>

            <!-- Main Action Button -->
            <button onclick="copyAndShop()" id="modal-main-btn"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-6 rounded-xl shadow-lg shadow-blue-500/30 text-lg transition-all transform hover:scale-105">
              <span id="modal-main-btn-text">انسخ الكود وتسوق</span>
            </button>

            <p id="modal-help-text" class="text-xs text-gray-400 mt-4">سيتم نسخ الكود وفتح موقع المتجر في صفحة جديدة.
            </p>
          </div>
        </div>

        <!-- Toast -->
        <div id="toast-container" class="fixed bottom-6 right-6 z-[300] flex flex-col gap-3 pointer-events-none"></div>

        <script src="/js/app.js"></script>
        <%- typeof script !=='undefined' ? script : '' %>
</body>

</html>