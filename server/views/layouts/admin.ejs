<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم | ركن الكوبونات</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300..900&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Rubik', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-100 min-h-screen">
    <div class="flex">
        <!-- Sidebar -->
        <aside class="w-64 bg-gray-900 text-white min-h-screen fixed right-0 top-0">
            <div class="p-6 border-b border-gray-800">
                <h1 class="text-xl font-black">ركن الكوبونات</h1>
                <p class="text-gray-400 text-xs mt-1">لوحة الإدارة v1.0</p>
            </div>
            <nav class="mt-6 p-4 space-y-2">
                <a href="/admin"
                    class="block px-4 py-3 rounded-xl transition-all <%= page === 'dashboard' ? 'bg-blue-600 text-white' : 'hover:bg-gray-800 text-gray-400' %>">🏠
                    الرئيسية</a>
                <a href="/admin/stores"
                    class="block px-4 py-3 rounded-xl transition-all <%= page === 'stores' ? 'bg-blue-600 text-white' : 'hover:bg-gray-800 text-gray-400' %>">🏪
                    المتاجر</a>
                <a href="/admin/coupons"
                    class="block px-4 py-3 rounded-xl transition-all <%= page === 'coupons' ? 'bg-blue-600 text-white' : 'hover:bg-gray-800 text-gray-400' %>">🎫
                    الكوبونات</a>
                <a href="/admin/rules"
                    class="block px-4 py-3 rounded-xl transition-all <%= page === 'rules' ? 'bg-blue-600 text-white' : 'hover:bg-gray-800 text-gray-400' %>">⚖️
                    القواعد</a>
                <a href="/admin/blog"
                    class="block px-4 py-3 rounded-xl transition-all <%= page === 'blog' ? 'bg-blue-600 text-white' : 'hover:bg-gray-800 text-gray-400' %>">📝
                    المدونة</a>
                <div class="pt-8 border-t border-gray-800">
                    <a href="/admin/logout"
                        class="block px-4 py-3 rounded-xl text-red-400 hover:bg-gray-800 transition-all">🚪 تسجيل
                        الخروج</a>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 mr-64 p-8">
            <header class="flex justify-between items-center mb-10">
                <div>
                    <h2 class="text-2xl font-black text-gray-800">أهلاً بك، المدير 👋</h2>
                    <p class="text-gray-500 text-sm">إليك ملخص ما يحدث اليوم</p>
                </div>
                <div class="flex gap-4">
                    <a href="/sa" target="_blank"
                        class="px-4 py-2 bg-white text-gray-700 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm font-bold flex items-center gap-2">
                        <span>👁️</span> معاينة الموقع
                    </a>
                </div>
            </header>

            <%- body %>
        </main>
    </div>
</body>

</html>