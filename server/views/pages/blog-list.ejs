<main class="container mx-auto px-4 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-black text-gray-800 mb-2">المدونة</h1>
        <p class="text-gray-500">مقالات وأدلة التسوق الذكي في <%= country ? country.name : '' %>
        </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        <div class="flex-1 min-w-0">
            <% if (blogPosts.length> 0) { %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
                    <% blogPosts.forEach(post=> { %>
                        <article
                            class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100 group">
                            <a href="/<%= countryCode %>/blog/<%= post.slug %>" class="block">
                                <div class="relative overflow-hidden h-48">
                                    <img src="<%= post.image %>" alt="<%= post.title %>"
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        loading="lazy">
                                    <% if (post.category) { %>
                                        <span
                                            class="absolute top-3 right-3 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">
                                            <%= post.category %>
                                        </span>
                                        <% } %>
                                </div>
                                <div class="p-5">
                                    <h2
                                        class="font-black text-gray-800 text-lg mb-2 line-clamp-2 group-hover:text-blue-600 transition-colors">
                                        <%= post.title %>
                                    </h2>
                                    <p class="text-gray-500 text-sm line-clamp-2 mb-4">
                                        <%= post.excerpt %>
                                    </p>
                                    <div class="flex items-center justify-between text-xs text-gray-400">
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                            <%= post.date %>
                                        </span>
                                        <span class="text-blue-600 font-bold">اقرأ المزيد ←</span>
                                    </div>
                                </div>
                            </a>
                        </article>
                        <% }) %>
                </div>
                <% } else { %>
                    <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
                        <div class="text-6xl mb-4">📝</div>
                        <p class="text-gray-500 font-medium">لا توجد مقالات متاحة حالياً</p>
                    </div>
                    <% } %>
        </div>

        <!-- Sidebar -->
        <aside class="w-full lg:w-80 shrink-0">
            <%- include('../partials/sidebar', { adBanners, recentPosts, socialConfig, countryCode, allStores: [],
                coupons: [] }) %>
        </aside>
    </div>
</main>