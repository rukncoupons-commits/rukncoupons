<header class="bg-white shadow-sm sticky top-0 z-50 border-b border-gray-100">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16 gap-4">

            <!-- Logo -->
            <a href="/<%= countryCode %>" class="flex items-center gap-2 shrink-0">
                <div class="bg-blue-600 text-white px-2 py-1 rounded font-black text-sm">ركن</div>
                <span class="font-black text-gray-800 text-lg hidden sm:block">الكوبونات</span>
            </a>

            <!-- Search Bar -->
            <form action="/<%= countryCode %>/stores" method="GET" class="flex-1 max-w-xl">
                <div class="relative">
                    <input type="text" name="q" placeholder="ابحث عن متجر أو كوبون..."
                        class="w-full bg-gray-100 rounded-xl px-4 py-2.5 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
                        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                    <button type="submit"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-blue-600 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                </div>
            </form>

            <!-- Nav + Country Switcher -->
            <nav class="flex items-center gap-1 shrink-0">
                <a href="/<%= countryCode %>/stores"
                    class="hidden md:block text-sm font-medium text-gray-600 hover:text-blue-600 px-3 py-2 rounded-lg hover:bg-blue-50 transition-all">المتاجر</a>
                <a href="/<%= countryCode %>/coupons"
                    class="hidden md:block text-sm font-medium text-gray-600 hover:text-blue-600 px-3 py-2 rounded-lg hover:bg-blue-50 transition-all">الكوبونات</a>
                <a href="/<%= countryCode %>/blog"
                    class="hidden md:block text-sm font-medium text-gray-600 hover:text-blue-600 px-3 py-2 rounded-lg hover:bg-blue-50 transition-all">المدونة</a>

                <!-- Country Switcher -->
                <div class="relative" id="country-dropdown-wrapper">
                    <button onclick="toggleCountryDropdown()" id="country-btn"
                        class="flex items-center gap-1.5 bg-gray-100 hover:bg-gray-200 rounded-xl px-3 py-2 text-sm font-medium transition-all">
                        <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icons/7.2.3/flags/1x1/<%= countryCode %>.svg"
                            class="w-5 h-5 rounded-full object-cover" alt="<%= countryCode %>">
                        <span class="hidden sm:block">
                            <%= countryCode.toUpperCase() %>
                        </span>
                        <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>
                    <div id="country-dropdown"
                        class="absolute left-0 top-full mt-2 bg-white rounded-2xl shadow-xl border border-gray-100 py-2 w-44 hidden z-50">
                        <% if (typeof countries !=='undefined' && countries.length> 0) { %>
                            <% countries.forEach(c=> { %>
                                <a href="javascript:void(0)" onclick="switchCountry('<%= c.code %>')"
                                    class="flex items-center gap-3 px-4 py-2.5 hover:bg-blue-50 transition-colors <%= c.code === countryCode ? 'bg-blue-50 text-blue-600 font-bold' : 'text-gray-700' %>">
                                    <img src="https://cdnjs.cloudflare.com/ajax/libs/flag-icons/7.2.3/flags/1x1/<%= c.code %>.svg"
                                        class="w-6 h-6 rounded-full object-cover" alt="<%= c.name %>">
                                    <span class="text-sm">
                                        <%= c.name %>
                                    </span>
                                </a>
                                <% }) %>
                                    <% } %>
                    </div>
                </div>
            </nav>
        </div>
    </div>
</header>